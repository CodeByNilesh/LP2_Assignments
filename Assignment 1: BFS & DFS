Assignment 1: BFS & DFS
 
CODE:

 #include <iostream>
#include <queue>
#include <vector>
using namespace std;
class Graph {
	int V;
	vector<int> adj[10];
public:
	Graph(int v) { V = v; }
	
	void addEdge(int u, int v) {
        adj[u].push_back(v);
        adj[v].push_back(u);
	}
	
	void BFS(int start) {
    	bool visited[10] = {false};
        queue<int> q;
    	
    	visited[start] = true;
    	q.push(start);
    	
    	cout << "BFS: ";
    	while (!q.empty()) {
        	int node = q.front();
        	q.pop();
        	cout << node << " ";
        	
        	for (int i : adj[node]) {
            	if (!visited[i]) {
                    visited[i] = true;
                    q.push(i);
            	}
        	}
    	}
    	cout << endl;
	}
	
	void DFS(int start) {
    	bool visited[10] = {false};
    	cout << "DFS: ";
    	DFSUtil(start, visited);
    	cout << endl;
	}
	
	void DFSUtil(int node, bool visited[]) {
    	visited[node] = true;
    	cout << node << " ";
    	
    	for (int i : adj[node]) {
        	if (!visited[i]) {
                DFSUtil(i, visited);
        	}
    	}
	}
};
 
int main() {
	Graph g(7);
	g.addEdge(0, 1);
	g.addEdge(0, 2);
	g.addEdge(1, 3);
	g.addEdge(1, 4);
	g.addEdge(2, 5);
	g.addEdge(2, 6);
	g.BFS(0);
	g.DFS(0);
	
	return 0;
}



 OUTPUT:
 
BFS: 0 1 2 3 4 5 6
DFS: 0 1 3 4 2 5 6



 
EXPLAINATION:

 BFS (Breadth-First Search)
●	Uses Queue (FIFO)
●	Visits level by level
●	Steps:
1.	Mark start node as visited, add to queue
2.	While queue not empty:
■	Remove front node, print it
■	Add all unvisited neighbors to queue
DFS (Depth-First Search)
●	Uses Recursion (or Stack)
●	Goes deep first, then backtracks
●	Steps:
1.	Mark current node as visited, print it
2.	Recursively visit all unvisited neighbors
 

